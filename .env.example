# OpenAI API key (required for LLM + embeddings)
OPENAI_API_KEY=sk-your-key-here

# ChromaDB persistence directory (defaults to ./chroma_data)
CHROMA_PERSIST_DIR=./chroma_data

# ChromaDB collection name
CHROMA_COLLECTION_NAME=company_knowledge

# OpenAI model for agents (defaults to gpt-3.5-turbo)
OPENAI_MODEL=gpt-3.5-turbo

# Embedding model
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Logging level
LOG_LEVEL=INFO

# Server settings
HOST=0.0.0.0
PORT=8000
