# ── Groq API (Free) ─────────────────────────────────────────
# Sign up at https://console.groq.com — no credit card required
GROQ_API_KEY=gsk_your-key-here

# Groq model to use (free tier available for all below)
# Options: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile

# ── Embeddings (100% Free, runs locally) ────────────────────
# No API key needed — runs on your CPU using sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ChromaDB persistence ─────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=company_knowledge

# ── Server ───────────────────────────────────────────────────
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
